# Faster early boot / hardware init tunables.
# Disable slow debug paths that are normally disabled in minimal.config but
# are worth enforcing when fast boot is the goal.
# CONFIG_DEBUG_KERNEL is not set
# CONFIG_DEBUG_MISC is not set
# CONFIG_DEBUG_FS is not set
# CONFIG_SLUB_DEBUG is not set
# CONFIG_SLUB_DEBUG_ON is not set
# CONFIG_SCHED_DEBUG is not set
# CONFIG_DEBUG_PREEMPT is not set
# CONFIG_DEBUG_LOCK_ALLOC is not set
# CONFIG_PROVE_LOCKING is not set
# CONFIG_LOCK_STAT is not set
# CONFIG_DYNAMIC_DEBUG is not set
# CONFIG_DEBUG_BUGVERBOSE is not set
# CONFIG_DEBUG_MEMORY_INIT is not set
# CONFIG_KALLSYMS is not set
# CONFIG_KALLSYMS_ALL is not set

# Run driver probes asynchronously where safe; this is the main kernel-side
# parallelism knob for hardware init.
CONFIG_DRIVER_ASYNC_PROBE=y

# Faster timer tick for more responsive early init (trades a little power).
CONFIG_HZ_1000=y

# Print initcall durations so slow boot phases can be identified.
CONFIG_DEBUG_INITCALL_TIMING=y

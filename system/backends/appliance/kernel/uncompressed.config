# Uncompressed x86 kernel payload.
# Requires CONFIG_EFI_STUB (the stub is still present, but the payload is not
# compressed). This avoids the kernel decompress step at boot.
# Only use on x86 kernels that support CONFIG_KERNEL_UNCOMPRESSED (Linux 7.0+).
# CONFIG_KERNEL_GZIP is not set
# CONFIG_KERNEL_BZIP2 is not set
# CONFIG_KERNEL_LZMA is not set
# CONFIG_KERNEL_XZ is not set
# CONFIG_KERNEL_LZO is not set
# CONFIG_KERNEL_LZ4 is not set
# CONFIG_KERNEL_ZSTD is not set
CONFIG_KERNEL_UNCOMPRESSED=y

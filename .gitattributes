# Alpenglow .gitattributes

# Shell scripts — LF line endings
# ponytail: linguist-detectable=false so CI scaffolding doesn't dominate lang stats
*.sh            text eol=lf linguist-detectable=false
*.bash          text eol=lf linguist-detectable=false
*.zsh           text eol=lf linguist-detectable=false

# Makefiles — LF line endings
Makefile        text eol=lf linguist-detectable=false
Makefile.*      text eol=lf linguist-detectable=false
*.mk            text eol=lf linguist-detectable=false

# Dockerfiles
Dockerfile      text eol=lf
Dockerfile.*    text eol=lf

# Rust source
*.rs            text diff=rust
*.toml          text

# Zig source
*.zig           text diff=zig
*.zon           text

# C source
*.c             text diff=cpp
*.h             text diff=cpp

# Kernel config files
*.config        text eol=lf

# JSON, YAML, TOML
*.json          text
*.yaml          text
*.yml           text
*.toml          text

# Markdown docs
*.md            text diff=markdown

# Text files
*.txt           text
*.cfg           text
*.conf          text

# Dinit service files (text with key=value)
dinit/*         text eol=lf linguist-detectable=false

# Run scripts in runit — shell, not project lang
run             text eol=lf linguist-detectable=false

# Init scripts — shell, not project lang
init            text eol=lf linguist-detectable=false

# OpenRC service scripts — shell, not project lang
system/alpine/openrc/*  text eol=lf linguist-detectable=false

# Root overlay scripts — shell, not project lang
system/alpine/rootfs-overlay/usr/local/bin/* text eol=lf linguist-detectable=false

# Appliance scripts
system/backends/appliance/scripts/* text eol=lf linguist-detectable=false

# Git files
.gitattributes  text eol=lf
.gitignore      text eof=lf

# Binary files — no diff, no text processing
*.ko            binary
*.o              binary
*.so             binary
*.a              binary
*.cpio.gz       binary
*.cpio.zst      binary
*.tar.gz        binary
*.tar.xz        binary
*.tar.zst       binary
*.xz            binary
*.zst           binary
*.gz            binary
*.bz2           binary
*.zip           binary
*.png           binary
*.jpg           binary
*.jpeg          binary
*.gif           binary
*.ico           binary
*.woff2         binary
*.ttf           binary
*.wasm          binary

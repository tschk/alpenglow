{
  "services": [
    {
      "id": "networking",
      "display_name": "Network",
      "run_as": "root",
      "restart": "system",
      "dependencies": [],
      "state_paths": []
    },
    {
      "id": "seatd",
      "display_name": "Seat Management",
      "run_as": "root",
      "restart": "always",
      "dependencies": [],
      "state_paths": [
        "/run/seatd.sock"
      ]
    },
    {
      "id": "alpenglow-kernel-policy",
      "display_name": "Kernel Policy",
      "run_as": "root",
      "restart": "system",
      "dependencies": [],
      "state_paths": [
        "/sys/fs/cgroup/alpenglow",
        "/run/alpenglow/runtime-state.env"
      ]
    },
    {
      "id": "alpenglow-netd",
      "display_name": "Network State Daemon",
      "run_as": "root",
      "restart": "always",
      "dependencies": [
        "networking",
        "alpenglow-kernel-policy"
      ],
      "state_paths": [
        "/run/alpenglow/netd/interfaces.json",
        "/run/alpenglow/netd/runtime-state.env"
      ]
    },
    {
      "id": "sold",
      "display_name": "Alpenglow Local Server",
      "run_as": "sold",
      "restart": "always",
      "dependencies": [
        "networking",
        "alpenglow-netd",
        "alpenglow-kernel-policy",
        "alpenglow-zram",
        "alpenglow-pressure"
      ],
      "state_paths": [
        "/var/lib/alpenglow/system",
        "/var/log/alpenglow"
      ]
    },
    {
      "id": "alpenglow-session",
      "display_name": "Alpenglow Session",
      "run_as": "root",
      "restart": "always",
      "dependencies": [
        "sold",
        "seatd",
        "alpenglow-zram",
        "alpenglow-pressure"
      ],
      "state_paths": [
        "/run/user/0",
        "/var/lib/alpenglow/browser"
      ]
    },
    {
      "id": "alpenglow-zram",
      "display_name": "Compressed Swap",
      "run_as": "root",
      "restart": "system",
      "dependencies": [
        "alpenglow-kernel-policy"
      ],
      "state_paths": [
        "/dev/zram0",
        "/proc/swaps",
        "/run/alpenglow/runtime-state.env"
      ]
    },
    {
      "id": "alpenglow-pressure",
      "display_name": "Pressure Policy",
      "run_as": "root",
      "restart": "always",
      "dependencies": [
        "alpenglow-kernel-policy",
        "alpenglow-zram"
      ],
      "state_paths": [
        "/proc/pressure",
        "/sys/fs/cgroup/alpenglow",
        "/run/alpenglow/runtime-state.env"
      ]
    },
    {
      "id": "remote-sync",
      "display_name": "Remote Sync Plugin",
      "run_as": "sold",
      "restart": "on-failure",
      "dependencies": [
        "sold"
      ],
      "optional": true,
      "state_paths": [
        "/var/lib/alpenglow/system/plugins"
      ]
    }
  ]
}

{
  "scripts": {
    "dev": "astro dev",
    "build:v86": "V86_SSH=1 sh scripts/build-v86-initramfs.sh",
    "build:v86:local": "sh scripts/build-v86-initramfs.sh",
    "build:site": "astro check --minimumSeverity error && astro build",
    "build": "V86_SSH=1 sh scripts/build-v86-initramfs.sh && bun run build:site",
    "preview": "astro preview",
    "deploy": "bun run build && wrangler pages deploy dist --project-name alpenglow"
  },
  "dependencies": {
    "@astrojs/check": "0.9.9",
    "astro": "7.0.6",
    "ghostty-web": "^0.4.0",
    "typescript": "6.0.3",
    "v86": "0.5.420"
  },
  "devDependencies": {
    "@unocss/astro": "^66.7.4",
    "unocss": "^66.7.4",
    "wrangler": "4.107.0"
  }
}

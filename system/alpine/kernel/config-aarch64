# Alpenglow aarch64 kernel config — minimal appliance + Rust
# Based on defconfig + kvm_guest + rust fragments
CONFIG_ARCH_ARM64=y
CONFIG_ARM64_VA_BITS_48=y
CONFIG_NR_CPUS=4
CONFIG_PREEMPT_NONE=y
CONFIG_RUST=y
CONFIG_RUST_IS_AVAILABLE=y
CONFIG_MODULES=n
CONFIG_MODULE_SIG=n
CONFIG_DEVTMPFS=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_EXT4_FS=y
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_XZ=y
CONFIG_SQUASHFS_ZSTD=y
CONFIG_EROFS_FS=y
CONFIG_EROFS_FS_ZSTD=y
CONFIG_BLK_DEV_INITRD=y
CONFIG_NET=y
CONFIG_INET=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_SERIAL_AMBA_PL011=y
CONFIG_SERIAL_AMBA_PL011_CONSOLE=y
CONFIG_PRINTK_TIME=y
CONFIG_CMDLINE_BOOL=y
CONFIG_CMDLINE="quiet console=ttyAMA0"
CONFIG_CMDLINE_OVERRIDE=n
# Build ID/signature metadata
CONFIG_MODULE_SIG_FORMAT=n
CONFIG_MODULE_SIG_ALL=n
CONFIG_TRUSTED_KEYS=n
CONFIG_SYSTEM_TRUSTED_KEYS=""
CONFIG_SYSTEM_EXTRA_CERTIFICATE=""
CONFIG_SECONDARY_TRUSTED_KEYRING=n
CONFIG_SYSTEM_TRUSTED_KEYRING=n
CONFIG_DEBUG_FS=n
CONFIG_DEBUG_KERNEL=n
CONFIG_FTRACE=n
CONFIG_STACKTRACE=n
CONFIG_UNWINDER_ORC=n
CONFIG_MAGIC_SYSRQ=n
# Disable unnecessary security (minimize kernel size)
CONFIG_SECURITY=n
CONFIG_SECURITYFS=n
CONFIG_SECURITY_NETWORK=n
CONFIG_LSM=""
CONFIG_INTEGRITY=n
CONFIG_IMA=n
CONFIG_EVM=n
# No modules
# CONFIG_MODULES is not set
# Minimal storage
# CONFIG_BLK_DEV is not set
# No SCSI/ATA (use virtio)
CONFIG_SCSI=n
CONFIG_ATA=n
CONFIG_SATA_AHCI=n
# No USB/storage
CONFIG_USB_SUPPORT=n
CONFIG_USB=n
CONFIG_SOUND=n
CONFIG_DRM=n
CONFIG_AGP=n
CONFIG_VIDEO=n
CONFIG_NFS_FS=n
CONFIG_NFS_V3=n
CONFIG_NFS_V4=n
CONFIG_CIFS=n
CONFIG_FUSE_FS=n
CONFIG_NLS=n
CONFIG_CRYPTO_MANAGER=n
CONFIG_CRYPTO_HMAC=n
CONFIG_CRYPTO_SHA256=n
CONFIG_CRYPTO_AES=n
CONFIG_RANDOM_TRUST_BOOTLOADER=y
CONFIG_NET_9P=y
CONFIG_9P_FS=y
CONFIG_9P_FS_POSIX_ACL=y
CONFIG_9P_FS_SECURITY=y
CONFIG_ARM64_CRYPTO=y
CONFIG_CRYPTO_AES_ARM64_CE_BLK=y
CONFIG_CRYPTO_GHASH_ARM64_CE=y
CONFIG_CRYPTO_SHA1_ARM64_CE=y
CONFIG_CRYPTO_SHA2_ARM64_CE=y
CONFIG_CRYPTO_SHA512_ARM64_CE=y

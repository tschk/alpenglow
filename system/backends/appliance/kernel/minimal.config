# Minimal appliance kernel profile from the original Alpenglow planning docs.
# Enables cgroup v2, PSI, MGLRU, zram, seccomp, Landlock, BBR/fq,
# EROFS/SquashFS, and namespaces so the kernel matches the OS design:
# dinit service graphs, per-process namespaces, capability handles, and
# immutable root filesystems.

# cgroup v2 + resource controllers
CONFIG_CGROUPS=y
CONFIG_CGROUP_SCHED=y
CONFIG_FAIR_GROUP_SCHED=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_MISC=y
CONFIG_CGROUP_BPF=y
CONFIG_BLK_CGROUP=y
CONFIG_MEMCG=y
CONFIG_CPUSETS=y
CONFIG_SCHED_MM_CID=y

# Namespaces
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_USER_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y

# Pressure, memory, and scheduler
CONFIG_PSI=y
CONFIG_PSI_DEFAULT_DISABLED=n
CONFIG_LRU_GEN=y
CONFIG_LRU_GEN_ENABLED=y

# Swap/compression
CONFIG_ZRAM=y
CONFIG_ZRAM_BACKEND_LZ4=y

# Sandboxing
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y
CONFIG_SECURITY_LANDLOCK=y

# TCP congestion
CONFIG_TCP_CONG_BBR=y
CONFIG_DEFAULT_BBR=y
CONFIG_NET_SCHED=y
CONFIG_NET_SCH_FQ=y
CONFIG_NET_SCH_FQ_CODEL=y
CONFIG_DEFAULT_FQ=y

# Immutable root filesystems
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_XZ=y
CONFIG_SQUASHFS_ZSTD=y
CONFIG_EROFS_FS=y
CONFIG_EROFS_FS_ZIP=y
CONFIG_EROFS_FS_ZIP_ZSTD=y
CONFIG_EROFS_FS_XATTR=y

# Framebuffer / console / input (browser-first boot path)
CONFIG_VT=y
CONFIG_VT_CONSOLE=y
CONFIG_DRM=y
CONFIG_DRM_KMS_HELPER=y
CONFIG_DRM_FBDEV_EMULATION=y
CONFIG_INPUT=y
CONFIG_INPUT_EVDEV=y
CONFIG_FRAMEBUFFER_CONSOLE=y

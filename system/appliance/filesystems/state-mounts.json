{
  "schema_version": 1,
  "state_root": {
    "mountpoint": "/state",
    "role": "persistent-state",
    "format": "ext4",
    "mount_options": [
      "rw",
      "nosuid",
      "nodev"
    ]
  },
  "binds": [
    {
      "source": "/state/home",
      "target": "/home",
      "owner": "root:root",
      "mode": "0755",
      "purpose": "user workspaces"
    },
    {
      "source": "/state/var/lib/alpenglow",
      "target": "/var/lib/alpenglow",
      "owner": "root:root",
      "mode": "0755",
      "purpose": "system state namespace"
    },
    {
      "source": "/state/var/cache/alpenglow",
      "target": "/var/cache/alpenglow",
      "owner": "alpenglow:alpenglow",
      "mode": "0700",
      "purpose": "browser and service cache"
    },
    {
      "source": "/state/var/log/alpenglow",
      "target": "/var/log/alpenglow",
      "owner": "root:root",
      "mode": "0700",
      "purpose": "appliance logs"
    }
  ],
  "directories": [
    {
      "path": "/state/home",
      "owner": "root:root",
      "mode": "0755"
    },
    {
      "path": "/state/var/lib/alpenglow/browser/profiles",
      "owner": "alpenglow:alpenglow",
      "mode": "0700"
    },
    {
      "path": "/state/var/lib/alpenglow/browser/cache",
      "owner": "alpenglow:alpenglow",
      "mode": "0700"
    },
    {
      "path": "/state/var/lib/alpenglow/browser/downloads",
      "owner": "alpenglow:alpenglow",
      "mode": "0700"
    },
    {
      "path": "/state/var/lib/alpenglow/browser/state",
      "owner": "alpenglow:alpenglow",
      "mode": "0700"
    },
    {
      "path": "/state/var/lib/alpenglow/browser/logs",
      "owner": "alpenglow:alpenglow",
      "mode": "0700"
    },
    {
      "path": "/state/var/lib/alpenglow/browser/terminal",
      "owner": "alpenglow:alpenglow",
      "mode": "0700"
    },
    {
      "path": "/state/var/lib/alpenglow/files",
      "owner": "sold:sold",
      "mode": "0700"
    },
    {
      "path": "/state/var/lib/alpenglow/system",
      "owner": "sold:sold",
      "mode": "0700"
    },
    {
      "path": "/state/var/lib/alpenglow/system/plugins",
      "owner": "sold:sold",
      "mode": "0700"
    },
    {
      "path": "/state/var/lib/alpenglow/oil",
      "owner": "root:root",
      "mode": "0755"
    },
    {
      "path": "/state/var/cache/alpenglow",
      "owner": "alpenglow:alpenglow",
      "mode": "0700"
    },
    {
      "path": "/state/var/log/alpenglow",
      "owner": "root:root",
      "mode": "0700"
    }
  ],
  "forbidden_persistent_paths": [
    "/root",
    "/etc",
    "/usr",
    "/opt",
    "/var/tmp"
  ]
}

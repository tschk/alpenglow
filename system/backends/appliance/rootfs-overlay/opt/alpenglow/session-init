# Alpenglow graphical session init
# Starts the Wayland compositor and default apps
set -eu

export XDG_RUNTIME_DIR=/run/user/$(id -u)
export WAYLAND_DISPLAY=wayland-1
export GDK_BACKEND=wayland
export QT_QPA_PLATFORM=wayland
export SDL_VIDEODRIVER=wayland
export _JAVA_AWT_WM_NONREPARENTING=1
export CLUTTER_BACKEND=wayland
export FREEDESKTOP_MONITORS=/run/user/$(id -u)/monitors

mkdir -p "${XDG_RUNTIME_DIR}"
chmod 700 "${XDG_RUNTIME_DIR}"
chown "${USER}" "${XDG_RUNTIME_DIR}"

# Start session wrapper
# This is called by greetd after authentication
exec /usr/local/bin/alpenglow-session-start 2>&1

# Alpenglow .gitattributes

# Shell scripts — LF line endings, diff as shell
*.sh            text eol=lf diff=shell
*.bash          text eol=lf diff=shell
*.zsh           text eol=lf diff=shell

# Makefiles — LF line endings
Makefile        text eol=lf
Makefile.*      text eol=lf
*.mk            text eol=lf

# Dockerfiles
Dockerfile      text eol=lf
Dockerfile.*    text eol=lf

# Rust source
*.rs            text diff=rust
*.toml          text

# Zig source
*.zig           text
*.zon           text

# C source
*.c             text diff=cpp
*.h             text diff=cpp

# Kernel config files
*.config        text eol=lf

# JSON, YAML, TOML
*.json          text
*.yaml          text
*.yml           text
*.toml          text

# Markdown docs
*.md            text diff=markdown

# Text files
*.txt           text
*.cfg           text
*.conf          text

# Dinit service files (text with key=value)
dinit/*         text eol=lf

# Run scripts in runit
run             text eol=lf

# Git files
.gitattributes  text eol=lf
.gitignore      text eof=lf

# Binary files — no diff, no text processing
*.ko            binary
*.o              binary
*.so             binary
*.a              binary
*.cpio.gz       binary
*.cpio.zst      binary
*.tar.gz        binary
*.tar.xz        binary
*.tar.zst       binary
*.xz            binary
*.zst           binary
*.gz            binary
*.bz2           binary
*.zip           binary
*.png           binary
*.jpg           binary
*.jpeg          binary
*.gif           binary
*.ico           binary
*.woff2         binary
*.ttf           binary
*.wasm          binary

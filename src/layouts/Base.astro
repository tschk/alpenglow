---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Alpenglow — immutable RAM-root Linux with persistent state." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">Alpenglow</a>
      <nav>
        <a href="/#model">Model</a>
        <a href="/#stack">Stack</a>
        <a href="/demo/">Demo</a>
        <a href="https://github.com/tschk/alpenglow">Source</a>
      </nav>
    </header>
    <slot />
    <footer class="site-footer">
      <p>
        <a href="https://github.com/tschk/alpenglow">GitHub</a>
        ·
        <a href="https://github.com/tschk/alpenglowed">Alpenglowed</a>
        ·
        <a href="https://tsc.hk">tsc.hk</a>
      </p>
    </footer>
  </body>
</html>

<style is:global>
  @font-face {
    font-family: "Geist Mono";
    font-style: normal;
    font-weight: 400;
    font-display: swap;
    src: url("/fonts/geist-mono-latin-400-normal.woff2") format("woff2");
  }

  :root {
    color-scheme: dark;
    --bg: #0a0a0a;
    --fg: #f2f2f2;
    --muted: #9a9a9a;
    --line: #2a2a2a;
    --accent: #ffffff;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    min-height: 100%;
    background: var(--bg);
    color: var(--fg);
    font: 15px / 1.55 ui-sans-serif, system-ui, sans-serif;
  }

  a {
    color: var(--accent);
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem clamp(1rem, 4vw, 3rem);
    border-bottom: 1px solid var(--line);
  }

  .brand {
    font-weight: 600;
    letter-spacing: 0.02em;
    text-decoration: none;
    color: var(--fg);
  }

  .site-header nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.5rem;
    font-size: 0.92rem;
  }

  .site-header nav a {
    color: var(--muted);
    text-decoration: none;
  }

  .site-header nav a:hover {
    color: var(--fg);
  }

  .site-footer {
    margin-top: 4rem;
    padding: 2rem clamp(1rem, 4vw, 3rem);
    border-top: 1px solid var(--line);
    color: var(--muted);
    font-size: 0.9rem;
  }

  .site-footer p {
    margin: 0;
  }

  main.page {
    max-width: 52rem;
    margin: 0 auto;
    padding: 2.5rem clamp(1rem, 4vw, 3rem) 3rem;
  }

  main.page h1 {
    margin: 0 0 0.75rem;
    font-size: clamp(1.75rem, 4vw, 2.35rem);
    line-height: 1.2;
    font-weight: 600;
  }

  main.page .lede {
    margin: 0 0 2.5rem;
    color: var(--muted);
    font-size: 1.05rem;
    max-width: 42rem;
  }

  main.page section {
    margin-bottom: 2.75rem;
  }

  main.page h2 {
    margin: 0 0 0.75rem;
    font-size: 1.15rem;
    font-weight: 600;
  }

  main.page h3 {
    margin: 1.5rem 0 0.5rem;
    font-size: 1rem;
    font-weight: 600;
  }

  main.page p,
  main.page li {
    color: #d4d4d4;
  }

  main.page ul {
    margin: 0.5rem 0 0;
    padding-left: 1.25rem;
  }

  main.page code {
    font-family: "Geist Mono", ui-monospace, monospace;
    font-size: 0.88em;
    background: #141414;
    padding: 0.1em 0.35em;
    border-radius: 3px;
  }

  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1rem;
    margin-top: 1.5rem;
  }

  .cta-row a.button {
    display: inline-block;
    padding: 0.55rem 1rem;
    border: 1px solid var(--line);
    text-decoration: none;
    color: var(--fg);
    font-size: 0.92rem;
  }

  .cta-row a.button.primary {
    border-color: var(--fg);
  }
</style>
# FAST-only overrides for aarch64.
# Use the Alpine virt config as a base, then trim and embed the initramfs.
CONFIG_KERNEL_GZIP=n
CONFIG_KERNEL_LZ4=y
CONFIG_BLK_DEV_INITRD=y
CONFIG_INITRAMFS_SOURCE="/out/initramfs-proper.cpio.lz4"
CONFIG_INITRAMFS_ROOT_UID=0
CONFIG_INITRAMFS_ROOT_GID=0
CONFIG_INITRAMFS_COMPRESSION_LZ4=y
CONFIG_INITRAMFS_COMPRESSION_NONE=n
CONFIG_INITRAMFS_PRESERVE_MTIME=n

# Additional FAST-only disables for aarch64.
# Keep only what headless diskless boot needs.
CONFIG_INTEGRITY=n
CONFIG_INTEGRITY_SIGNATURE=n
CONFIG_IMA=n
CONFIG_EVM=n
CONFIG_AUDIT=n
CONFIG_AUDITSYSCALL=n
CONFIG_SECURITY_SELINUX=n
CONFIG_SECURITY_APPARMOR=n
CONFIG_SECURITY_SMACK=n
CONFIG_SECURITY_TOMOYO=n
CONFIG_SECURITY_LANDLOCK=n
CONFIG_SECURITY_LOCKDOWN_LSM=n
CONFIG_SECURITY_LOCKDOWN_LSM_EARLY=n
CONFIG_KEYS=n
CONFIG_KEYS_REQUEST_CACHE=n
CONFIG_ASYMMETRIC_KEY_TYPE=n
CONFIG_ASYMMETRIC_PUBLIC_KEY_SUBTYPE=n
CONFIG_X509_CERTIFICATE_PARSER=n
CONFIG_PKCS7_MESSAGE_PARSER=n
CONFIG_SYSTEM_BLACKLIST_KEYRING=n
CONFIG_SYSTEM_DATA_VERIFICATION=n
CONFIG_MODULE_SIG=n
CONFIG_MODULE_SIG_ALL=n
CONFIG_MODULE_SIG_SHA256=n
CONFIG_MODULE_SIG_FORCE=n
CONFIG_MODULE_SIG_VERIFY=n
CONFIG_COREDUMP=n

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Alpenglow running in the browser." />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <title>Alpenglow</title>
  </head>
  <body>
    <main id="screen_container" aria-label="Alpenglow OS">
      <div></div>
      <canvas></canvas>
      <textarea id="serial" spellcheck="false" aria-label="Alpenglow console"></textarea>
      <section id="boot_status" aria-live="polite">
        <p id="boot_message">loading alpenglow shell</p>
        <meter id="boot_progress" min="0" max="100" value="0">0%</meter>
      </section>
    </main>
    <script src="/app.js?v=20260705-bios-clean" type="module"></script>
  </body>
</html>

<style>
  @font-face {
    font-family: "Geist Mono";
    font-style: normal;
    font-weight: 400;
    font-display: swap;
    src: url("/fonts/geist-mono-latin-400-normal.woff2") format("woff2");
  }

  :root {
    color-scheme: dark;
    background: #000;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body,
  #screen_container {
    width: 100%;
    height: 100%;
    margin: 0;
    overflow: hidden;
  }

  body {
    background: #000;
    color: #fff;
  }

  #screen_container {
    position: fixed;
    inset: 0;
  }

  #screen_container > div,
  #screen_container > canvas {
    display: none;
  }

  #serial {
    display: block;
    width: 100vw;
    height: 100vh;
    padding: clamp(12px, 2vw, 22px);
    border: 0;
    outline: 0;
    resize: none;
    background: #000;
    color: #fff;
    font: 12px / 1.35 "Geist Mono", ui-monospace, monospace;
    letter-spacing: 0;
  }

  #boot_status {
    position: fixed;
    left: clamp(14px, 2.4vw, 30px);
    right: clamp(14px, 2.4vw, 30px);
    bottom: clamp(14px, 2.4vw, 30px);
    display: grid;
    gap: 10px;
    max-width: 520px;
    pointer-events: none;
    font: 12px / 1.35 "Geist Mono", ui-monospace, monospace;
  }

  #boot_status[hidden] {
    display: none;
  }

  #boot_message {
    margin: 0;
    color: #fff;
  }

  #boot_progress {
    width: 100%;
    height: 12px;
    accent-color: #fff;
  }
</style>

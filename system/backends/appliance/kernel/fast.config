# FAST profile overrides: shrink the kernel and embed the initramfs.
# Applied on top of alpenglow-qemu-minimal.config + lz4.config + virt.config.

# Shrink: drop subsystems not needed for headless diskless boot
CONFIG_DRM=n
CONFIG_DRM_BRIDGE=n
CONFIG_DRM_PANEL=n
CONFIG_DRM_PANEL_ORIENTATION_QUIRKS=n
CONFIG_DRM_VIRTIO_GPU=n
CONFIG_SOUND=n
CONFIG_SND=n
CONFIG_USB=n
CONFIG_USB_SUPPORT=n
CONFIG_USB_COMMON=n
CONFIG_USB_ARCH_HAS_HCD=n
CONFIG_USB_PCI=n
CONFIG_USB_XHCI_HCD=n
CONFIG_USB_EHCI_HCD=n
CONFIG_USB_UHCI_HCD=n
CONFIG_HID_SUPPORT=n
CONFIG_HID=n
CONFIG_KALLSYMS=n
CONFIG_KALLSYMS_BASE_RELATIVE=n
CONFIG_KALLSYMS_SELFTEST=n
CONFIG_BLK_DEV_BSG=n
CONFIG_BLK_DEV_BSG_COMMON=n
CONFIG_WATCHDOG=n
CONFIG_WATCHDOG_CORE=n
CONFIG_SOFT_WATCHDOG=n
CONFIG_THERMAL=n
CONFIG_THERMAL_GOV_FAIR_SHARE=n
CONFIG_THERMAL_GOV_STEP_WISE=n
CONFIG_THERMAL_GOV_USER_SPACE=n
CONFIG_THERMAL_GOV_POWER_ALLOCATOR=n
CONFIG_THERMAL_EMERGENCY_POWEROFF_DELAY_MS=0
CONFIG_HUGETLBFS=n
CONFIG_HUGETLB_PAGE=n
CONFIG_TRANSPARENT_HUGEPAGE=n
CONFIG_FTRACE=n
CONFIG_TRACING=n
CONFIG_KPROBES=n
CONFIG_UPROBES=n
CONFIG_BPF=n
CONFIG_BPF_SYSCALL=n
CONFIG_BPF_JIT=n
CONFIG_PERF_EVENTS=n
CONFIG_HAVE_PERF_EVENTS=n

# Disable debug overhead
CONFIG_DEBUG_KERNEL=n
CONFIG_DEBUG_MISC=n
CONFIG_DEBUG_FS=n
CONFIG_DEBUG_BUGVERBOSE=n
CONFIG_DEBUG_LIST=n
CONFIG_DEBUG_SG=n
CONFIG_DEBUG_NOTIFIERS=n
CONFIG_DEBUG_CREDENTIALS=n
CONFIG_DEBUG_ATOMIC_SLEEP=n
CONFIG_SLUB_DEBUG=n
CONFIG_SLUB_DEBUG_ON=n
CONFIG_MAGIC_SYSRQ=n
CONFIG_PRINTK_TIME=n
CONFIG_DYNAMIC_DEBUG=n
CONFIG_DYNAMIC_DEBUG_CORE=n

# Skip a few mitigations for speed in FAST/QEMU only
CONFIG_MITIGATION_RETPOLINE=n
CONFIG_MITIGATION_RETHUNK=n
CONFIG_MITIGATION_SPECTRE_V1=n
CONFIG_MITIGATION_SPECTRE_V2=n
CONFIG_MITIGATION_SPEC_STORE_BYPASS=n
CONFIG_MITIGATION_SRSO=n
CONFIG_MITIGATION_GDS=n
CONFIG_MITIGATION_RFDS=n
CONFIG_MITIGATION_BHI=n
CONFIG_RANDOMIZE_BASE=n
CONFIG_RANDOMIZE_KSTACK_OFFSET=n

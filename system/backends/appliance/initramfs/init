#!/bin/sh
# ──────────────────────────────────────────────────────────────────────
# Alpenglow init — diskless immutable root
# ──────────────────────────────────────────────────────────────────────
set -eu

mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t devtmpfs devtmpfs /dev

mkdir -p /dev/shm /run /tmp /sysroot
mount -t tmpfs -o mode=1777,size=256m tmpfs /dev/shm
mkdir -p /run/user/0 /tmp

# Parse kernel cmdline
ALPENGLOW_IMAGE=""
ALPENGLOW_STATE=""
ALPENGLOW_DEBUG=""

for arg in $(cat /proc/cmdline); do
  case "${arg}" in
    alpenglow.image=*)  ALPENGLOW_IMAGE="${arg#alpenglow.image=}" ;;
    alpenglow.state=*)  ALPENGLOW_STATE="${arg#alpenglow.state=}" ;;
    alpenglow.debug)    ALPENGLOW_DEBUG="1" ;;
  esac
done

[ -n "${ALPENGLOW_DEBUG}" ] && set -x

for m in erofs squashfs bcachefs virtio-blk virtio-net \
         snd snd-pcm cfg80211 mac80211 iwlwifi ath9k \
         hid usbhid i2c-dev acpi-cpufreq; do
  (modprobe "$m" 2>/dev/null || true) &
done
wait

find_image() {
  if [ -n "${ALPENGLOW_IMAGE}" ] && [ -f "${ALPENGLOW_IMAGE}" ]; then
    echo "${ALPENGLOW_IMAGE}"; return
  fi
  for ext in erofs squashfs; do
    img="/sysroot/alpenglow/current.${ext}"
    [ -f "${img}" ] && echo "${img}" && return
  done
  local found
  found=$(blkid -L alpenglow-boot 2>/dev/null || true)
  if [ -n "${found}" ]; then
    mount -r "${found}" /mnt 2>/dev/null || true
    for ext in erofs squashfs; do
      img="/mnt/alpenglow/current.${ext}"
      if [ -f "${img}" ]; then cp "${img}" "/sysroot/alpenglow/current.${img##*.}" 2>/dev/null; umount /mnt; echo "/sysroot/alpenglow/current.${img##*.}"; return; fi
    done
    umount /mnt 2>/dev/null || true
  fi
  for dev in /dev/vda* /dev/sda* /dev/nvme0n1* /dev/mmcblk0*; do
    [ -b "${dev}" ] || continue
    mount -r "${dev}" /mnt 2>/dev/null || continue
    for ext in erofs squashfs; do
      img="/mnt/alpenglow/current.${ext}"
      if [ -f "${img}" ]; then
        cp "${img}" "/sysroot/alpenglow/current.${img##*.}" 2>/dev/null
        umount /mnt; echo "/sysroot/alpenglow/current.${img##*.}"; return
      fi
    done
    umount /mnt 2>/dev/null || true
  done
  echo ""
}

ROOT_IMAGE=$(find_image)
if [ -z "${ROOT_IMAGE}" ]; then
  echo "Alpenglow: no immutable root image found, falling back to shell" >&2
  echo "  To boot diskless: add alpenglow.image=<path> to kernel cmdline" >&2
  exec /bin/sh
fi

echo "Alpenglow: mounting ${ROOT_IMAGE}..."
case "${ROOT_IMAGE}" in
  *.erofs)     mount -t erofs -o ro,nodev "${ROOT_IMAGE}" /mnt/root ;;
  *.squashfs)  mount -t squashfs -o ro,nodev "${ROOT_IMAGE}" /mnt/root ;;
esac

if [ -n "${ALPENGLOW_STATE}" ]; then
  mount -t bcachefs -o rw,nosuid,nodev "${ALPENGLOW_STATE}" /mnt/root/state 2>/dev/null || { echo "Alpenglow: bcachefs state mount failed: ${ALPENGLOW_STATE}" >&2; exec /bin/sh; }
else
  mount -t bcachefs -o rw,nosuid,nodev LABEL=alpenglow-state /mnt/root/state 2>/dev/null || { echo "Alpenglow: bcachefs state mount failed: LABEL=alpenglow-state" >&2; exec /bin/sh; }
fi

exec switch_root /mnt/root /sbin/init

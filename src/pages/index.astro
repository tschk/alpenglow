<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Alpenglow running in the browser." />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>Alpenglow</title>
  </head>
  <body>
    <main id="screen_container" aria-label="Alpenglow OS">
      <div></div>
      <canvas></canvas>
      <textarea id="serial" spellcheck="false" aria-label="Alpenglow console"></textarea>
    </main>
    <script src="/app.js" type="module"></script>
  </body>
</html>

<style>
  :root {
    color-scheme: dark;
    background: #050706;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body,
  #screen_container {
    width: 100%;
    height: 100%;
    margin: 0;
    overflow: hidden;
  }

  body {
    background: #050706;
  }

  #screen_container {
    position: fixed;
    inset: 0;
  }

  #screen_container > div,
  #screen_container > canvas {
    display: none;
  }

  #serial {
    display: block;
    width: 100vw;
    height: 100vh;
    padding: clamp(14px, 2.4vw, 30px);
    border: 0;
    outline: 0;
    resize: none;
    background: #050706;
    color: #f0b35a;
    font: clamp(13px, 1.55vw, 18px) / 1.45 ui-monospace, "SFMono-Regular", Menlo, monospace;
    letter-spacing: 0;
  }
</style>

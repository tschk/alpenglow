ALPENGLOW_START_URL="os://terminal"
ALPENGLOW_SESSION_X11_FALLBACK=0
ALPENGLOW_SESSION_HEADLESS_FALLBACK=1
ALPENGLOW_KERNEL_POLICY_REQUIRED=1
ALPENGLOW_GENERATION_FILE="/etc/alpenglow/generation.json"
ALPENGLOW_MARK_GOOD_HOOK="/usr/local/bin/alpenglow-generation-mark-good"
ALPENGLOW_UPDATE_STATE="/var/lib/alpenglow/system/update-state.json"
# Seconds to sleep on non-zero session exit before OpenRC respawns.
ALPENGLOW_SESSION_FAILURE_DELAY=8

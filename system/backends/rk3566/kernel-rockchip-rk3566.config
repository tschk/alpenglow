# RK3566-specific driver additions for the arm64 defconfig.
# These are not enabled by default in the upstream arm64 defconfig but are
# required to boot Alpenglow on Rockchip RK3566 boards (Orange Pi 3B, Quartz64,
# SOQuartz, etc.).

# Ethernet
CONFIG_DWMAC_ROCKCHIP=y
CONFIG_MOTORCOMM_PHY=y
CONFIG_REALTEK_PHY=y
CONFIG_STMMAC_ETH=y
CONFIG_STMMAC_PLATFORM=y

# RK809 / RK817 PMIC (power, regulators, RTC)
CONFIG_MFD_RK808=y
CONFIG_REGULATOR_RK808=y
CONFIG_RTC_RK808=y

# SDIO / eMMC (SOQuartz carrier and some Wi-Fi modules)
CONFIG_MMC_SDHCI_DW=y

CONFIG_BT=y
CONFIG_BT_BREDR=y
CONFIG_BT_LE=y
CONFIG_BT_BCM=y
CONFIG_BT_HCIUART=y
CONFIG_BT_HCIUART_BCM=y
CONFIG_BT_HCIUART_H4=y
CONFIG_BT_HCIUART_SERDEV=y
CONFIG_RFKILL=y
CONFIG_RFKILL_GPIO=y
CONFIG_SERIAL_8250_DW=y
CONFIG_SERIAL_DEV_BUS=y
CONFIG_SERIAL_DEV_CTRL_TTYPORT=y

# CPU frequency scaling
CONFIG_ARM_ROCKCHIP_CPUFREQ=y

# USB OTG controller for the USB-C / OTG port
CONFIG_USB_DWC3_DUAL_ROLE=y

# IP block power domains
CONFIG_ROCKCHIP_PM_DOMAINS=y

# Thermal management
CONFIG_ROCKCHIP_THERMAL=y

# Alpenglow browser v86 (i686): serial console + initrd only
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_TMPFS=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_NR_UARTS=4
CONFIG_TTY_SERIAL=y
CONFIG_PCI=y
CONFIG_ACPI=y
CONFIG_ATA=n
CONFIG_DRM=n
CONFIG_SOUND=n
CONFIG_USB_SUPPORT=n
# Disable TCPMSS netfilter modules that fail to build in the v86 i686 config.
CONFIG_NETFILTER_XT_TARGET_TCPMSS=n
CONFIG_NETFILTER_XT_MATCH_TCPMSS=n